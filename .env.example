# Скопировать в .env и заполнить

# Обязательно
DJANGO_SECRET_KEY=замените-на-случайную-строку-50-символов

# Хосты (через запятую)
DJANGO_ALLOWED_HOSTS=attestation.by,www.attestation.by

# Gunicorn
GUNICORN_BIND=127.0.0.1:8022
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# Email (Яндекс SMTP)
EMAIL_HOST_USER=info@attestation.by
EMAIL_HOST_PASSWORD=
CONTACT_EMAIL=info@attestation.by

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
