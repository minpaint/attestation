# Скопировать в /home/django/webapps/attestation/.env и заполнить

# --- Обязательно ---
DJANGO_SECRET_KEY=замените-на-случайную-строку-50+-символов
DJANGO_ALLOWED_HOSTS=attestation.by,www.attestation.by

# --- Почта (Yandex SMTP) ---
EMAIL_HOST_USER=ваш@yandex.ru
EMAIL_HOST_PASSWORD=пароль-приложения-яндекс
CONTACT_EMAIL=куда-получать-заявки@example.com

# --- Telegram (опционально) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=-100123456789

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_BIND=127.0.0.1:8022
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# --- Необязательно (есть разумные значения по умолчанию) ---
# DJANGO_DEBUG=0
# DJANGO_SSL_REDIRECT=1
# DJANGO_HSTS_SECONDS=31536000
# CONTACT_RATE_LIMIT=5
# CONTACT_RATE_WINDOW=3600
